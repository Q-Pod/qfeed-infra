// ==========================================================================
// Backend EC2 Alloy Configuration (Dev)
// 1. Host metrics → Prometheus remote_write (push)
// 2. Docker container logs → Loki push
// ==========================================================================

// --- Host Metrics ---

prometheus.exporter.unix "host" {
	procfs_path = "/host/proc"
	sysfs_path  = "/host/sys"
}

prometheus.scrape "node" {
	targets    = prometheus.exporter.unix.host.targets
	forward_to = [prometheus.relabel.set_labels.receiver]
}

prometheus.relabel "set_labels" {
	rule {
		target_label = "instance"
		replacement  = env("EC2_NAME")
	}
	rule {
		target_label = "job"
		replacement  = "node"
	}
	forward_to = [prometheus.remote_write.default.receiver]
}

prometheus.remote_write "default" {
	external_labels = {
		environment = "dev",
		role        = "backend",
	}
	endpoint {
		url = "http://10.1.3.90:9090/api/v1/write"
	}
}

// --- Docker Container Logs → Loki ---

discovery.docker "containers" {
	host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_logs" {
	targets = discovery.docker.containers.targets

	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/(.*)"
		target_label  = "container"
	}

	rule {
		target_label = "job"
		replacement  = "docker-logs"
	}
	rule {
		target_label = "environment"
		replacement  = "dev"
	}
	rule {
		target_label = "role"
		replacement  = "backend"
	}
}

loki.source.docker "containers" {
	host       = "unix:///var/run/docker.sock"
	targets    = discovery.relabel.docker_logs.output
	forward_to = [loki.write.default.receiver]
}

loki.write "default" {
	endpoint {
		url = "http://10.1.3.90:3100/loki/api/v1/push"
	}
}

prometheus.scrape "cadvisor" {
    targets = [{
        __address__ = "localhost:8082",
    }]
    scrape_interval = "10s"
    forward_to      = [prometheus.relabel.cadvisor_labels.receiver]
}

prometheus.relabel "cadvisor_labels" {
    rule {
        target_label = "instance"
        replacement  = env("EC2_NAME")
    }
    rule {
        target_label = "job"
        replacement  = "cadvisor"
    }
    forward_to = [prometheus.remote_write.default.receiver]
}

prometheus.receive_http "k6" {
    http {
        listen_address = "0.0.0.0"
        listen_port    = 9999
    }
    forward_to = [prometheus.remote_write.default.receiver]
}
