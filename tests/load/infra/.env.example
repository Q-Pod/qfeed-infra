# 부하테스트 환경변수 템플릿
# 이 파일을 .env로 복사한 후 값을 채워서 사용하세요.
# cp .env.example .env

# --- DB ---
POSTGRES_DB=qfeed
POSTGRES_USER=qfeed
POSTGRES_PASSWORD=qfeed-loadtest

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=qfeed-loadtest

# --- Spring (BE) ---
SPRING_PROFILES_ACTIVE=loadtest
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/qfeed
SPRING_DATASOURCE_USERNAME=qfeed
SPRING_DATASOURCE_PASSWORD=qfeed-loadtest
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver

# --- JWT ---
JWT_SECRET=loadtest-jwt-secret-key-minimum-32-characters-long

# --- AI Service (BE → AI 내부 통신) ---
AI_FEEDBACK_BASE_URL=http://ai:8000
AI_STT_BASE_URL=http://ai:8000

# --- OAuth (테스트용 더미값) ---
KAKAO_CLIENT_ID=loadtest-dummy
KAKAO_CLIENT_SECRET=loadtest-dummy
KAKAO_REDIRECT_URI=http://localhost:8080/oauth/callback
OAUTH2_FRONTEND_REDIRECT_URI=http://localhost:3000/oauth/callback

# --- CORS ---
CORS_ALLOWED_ORIGIN=*

# --- AWS S3 (필요시 실제값 입력) ---
AWS_REGION=ap-northeast-2
AWS_S3_UPLOAD_BUCKET_NAME=
AWS_S3_TTS_BUCKET_NAME=
AWS_S3_CDN_URL_PREFIX=

# --- AI 서비스 (더미값으로 기동 가능, 실제 AI 기능 테스트 시 실제값 필요) ---
HUGGINGFACE_API_KEY=dummy-loadtest
GEMINI_API_KEY=dummy-loadtest
ELEVENLABS_API_KEY=dummy-loadtest
LANGFUSE_PUBLIC_KEY=dummy-loadtest
LANGFUSE_SECRET_KEY=dummy-loadtest
GPU_STT_URL=http://localhost:9999
GPU_LLM_URL=http://localhost:9999
ENVIRONMENT=dev
AWS_PARAMETER_STORE_PATH=/qfeed/dev/ai

# --- 기타 ---
INTERVIEW_SESSION_REAL_MAX_TURN=5
